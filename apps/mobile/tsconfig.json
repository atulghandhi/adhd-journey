{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@focuslab/shared": [
        "../../packages/shared/src/index.ts"
      ],
      "@focuslab/shared/*": [
        "../../packages/shared/src/*"
      ]
    },
    "strict": true,
    "types": [
      "nativewind/types",
      "jest"
    ]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "nativewind-env.d.ts"
  ]
}
