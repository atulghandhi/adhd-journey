# =============================================================================
# FocusLab Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
#   cp .env.example .env.local
#
# For LOCAL DEVELOPMENT, only the Supabase variables are required.
# Run `supabase start` and it will print the URL and keys to use below.
# All other services gracefully stub when their keys are missing.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (REQUIRED for all development)
# -----------------------------------------------------------------------------
# Get these from `supabase start` output (local) or Supabase dashboard (production)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — used by Edge Functions only. NEVER expose to client apps.
SUPABASE_SERVICE_ROLE_KEY=

# Expo / Mobile — same Supabase values, prefixed for Expo (Expo ignores NEXT_PUBLIC_)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# -----------------------------------------------------------------------------
# Firebase Cloud Messaging — Push Notifications
# -----------------------------------------------------------------------------
# Get from: Firebase Console → Project Settings → Cloud Messaging → Server key
# If missing: notifications will log [STUB] warnings and skip push sends
FCM_SERVER_KEY=

# -----------------------------------------------------------------------------
# Resend — Email Notifications
# -----------------------------------------------------------------------------
# Get API key from: https://resend.com/api-keys
# Get from email: verify a domain at https://resend.com/domains
# If missing: email notifications will log [STUB] warnings and skip sends
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# -----------------------------------------------------------------------------
# RevenueCat — In-App Purchases / Payments
# -----------------------------------------------------------------------------
# Get from: https://app.revenuecat.com → Project Settings → API Keys
# Public key: used in mobile app (react-native-purchases SDK)
# Secret key: used in verify-payment Edge Function for webhook validation
# If missing: paywall shows "Dev mode: bypass payment" button
REVENUECAT_PUBLIC_SDK_KEY=
REVENUECAT_SECRET_KEY=

# -----------------------------------------------------------------------------
# OAuth Providers (optional — for social login)
# -----------------------------------------------------------------------------
# Configure in Supabase dashboard → Authentication → Providers
# If missing: social login buttons will be hidden, email/password still works
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# APPLE_CLIENT_ID=
# APPLE_CLIENT_SECRET=
